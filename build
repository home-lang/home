#!/usr/bin/env bash
# Top-level build wrapper.
#
# `zig build` is currently broken on macOS 26 with zig 0.16-dev: the bundled
# libSystem stubs don't cover the symbols zig std needs to link the build
# runner itself (sigaction, dispatch_*, sysctlbyname, etc.). This wrapper
# bypasses the broken runner and invokes `zig build-exe` directly via
# `scripts/manual_build.sh`, which builds cleanly.
#
# Usage:
#   ./build         # build the compiler
#   ./build test    # build, then run unit tests
#   ./build clean   # remove build artifacts
#   ./build run X   # build, then run with the given args
#
# When upstream zig ships fresh libSystem stubs this wrapper can be deleted
# and `zig build` will Just Work again.

set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

cmd="${1:-build}"
shift || true

case "$cmd" in
    build|"")
        exec bash scripts/manual_build.sh "$@"
        ;;
    test)
        bash scripts/manual_build.sh
        echo
        echo "=== running tests ==="
        exec bash scripts/run_tests.sh "$@"
        ;;
    examples)
        bash scripts/manual_build.sh
        echo
        echo "=== checking examples ==="
        exec bash scripts/check-examples.sh "$@"
        ;;
    clean)
        rm -rf zig-out .zig-cache
        echo "cleaned zig-out and .zig-cache"
        ;;
    run)
        bash scripts/manual_build.sh
        exec ./zig-out/bin/home "$@"
        ;;
    help|-h|--help)
        sed -n '3,18p' "$0"
        ;;
    *)
        echo "unknown subcommand: $cmd" >&2
        echo "run \`./build help\` for usage" >&2
        exit 2
        ;;
esac
