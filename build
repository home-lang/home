#!/usr/bin/env bash
# Top-level build wrapper — bypasses the broken `zig build` on macOS 26.

set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

cmd="${1:-build}"
shift || true

case "$cmd" in
    build|"")
        exec bash scripts/manual_build.sh "$@"
        ;;
    test)
        bash scripts/manual_build.sh
        echo
        echo "=== running tests ==="
        exec bash scripts/run_tests.sh "$@"
        ;;
    examples)
        bash scripts/manual_build.sh
        echo
        echo "=== checking examples ==="
        exec bash scripts/check-examples.sh "$@"
        ;;
    regression)
        bash scripts/manual_build.sh
        echo
        echo "=== regression tests ==="
        exec bash scripts/regression_tests.sh "$@"
        ;;
    clean)
        rm -rf zig-out .zig-cache
        echo "cleaned zig-out and .zig-cache"
        ;;
    run)
        bash scripts/manual_build.sh
        exec ./zig-out/bin/home "$@"
        ;;
    help|-h|--help)
        sed -n '3,8p' "$0"
        ;;
    *)
        echo "unknown subcommand: $cmd" >&2
        exit 2
        ;;
esac
