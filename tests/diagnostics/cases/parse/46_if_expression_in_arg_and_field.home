// Regression test for issue #54 — `if (cond) a else b` parses as an
// expression in any expression position: function-call argument,
// struct-field initializer, let/const initializer, return value,
// and inside arithmetic. Before the fix the parser hard-required a
// `{` after the if-condition and bailed with `Expected '{' after if
// condition` whenever an if appeared in expression context.
//
// The two arms parse as expressions (not blocks); `else` is the
// branch separator and is mandatory in expression form. Lowered onto
// the existing `IfExpr` AST node so the typechecker / codegen don't
// need a parallel path.

fn write_string(s: []const u8) -> void {
    return
}

// Argument position — `kernel/src/security/capabilities.home:410`.
fn audit_log(audit_cap_checks: u32) -> void {
    write_string(if (audit_cap_checks == 1) "ON" else "OFF")
}

// Let initializer — `kernel/src/iot/audio_processing.home:336`.
fn clamp_snr(snr: f64) -> f64 {
    const snr_clamped = if (snr < 0.0) 0.0 else snr
    return snr_clamped
}

// Return position.
fn pick(c: bool) -> i32 {
    return if (c) 1 else 0
}

// Inside arithmetic — paren-grouped if-expr feeds a `+`.
fn step(c: bool, x: i32) -> i32 {
    return x + (if (c) 1 else 0)
}

// Nested in another if-expr's else branch (chained ternary form).
fn classify(x: i32) -> i32 {
    return if (x < 0) -1 else if (x > 0) 1 else 0
}
