// Issue #32: `@atomicFetchSub(ptr, val)` is recognised as an opaque
// builtin for atomic fetch-then-subtract. The parser consumes its
// arguments and lowers to a Void expression, so callers like
// `var prev = @atomicFetchSub(&counter, 1u32)` no longer report
// "Unknown reflection function".
fn caller(p: *u32) {
    var prev = @atomicFetchSub(p, 1u32)
}
