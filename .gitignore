**/zig-out/
**/.test-cache/

# OS detritus
.DS_Store
**/.DS_Store

# Stale top-level test binaries / scratch outputs from ad-hoc runs.
# Anchored to the repo root with a leading slash so they do NOT match
# files under tests/ (e.g. tests/feature/test_*.test.home is fine).
/test_reify
/test_reify2
/test_timer
/test_type
/test_type2
/test_typeinfo
/a.out

# Compiled example binaries (sources are .home/.hm files in the same dir)
